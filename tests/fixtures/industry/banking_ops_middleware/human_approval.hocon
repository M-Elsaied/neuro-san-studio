# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

{
    # Describes what agent to test against.
    "agent": "industry/banking_ops_middleware",

    # Timeout for the entire test.
    "timeout_in_seconds": 180,

    # success_ratio is useful for passing to the assessor to find out why
    # a test is intermittently failing.
    "success_ratio": "1/1",

    # Connect to the agent via a server
    "connections": ["direct"],

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks.
    "interactions": [
        {
            # A large international wire transfer request that should trigger
            # the HumanApprovalMiddleware on the account_manager, requiring
            # manager authorization before the transfer can proceed.
            "text": """
I need to wire $50,000 from my checking account to an international account in Switzerland. The beneficiary is Alpen Financial Group, IBAN CH93 0076 2011 6238 5295 7. Please process this today.
""",

            # The response block treats how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # The agent should address the wire transfer request.
                    "keywords": ["wire"],
                }
            }
        }
    ]
}
